# GEMINI_API_KEY: Required for Gemini AI API calls.
# This is a placeholder key.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY=MY_GEMINI_API_KEY

# FIREBASE CONFIGURATION: Loaded via Secrets Gradle Plugin
FIREBASE_API_KEY=AIzaSy_YOUR_FIREBASE_API_KEY_PLACEHOLDER
FIREBASE_PROJECT_ID=tradefit-erp-placeholder
FIREBASE_APPLICATION_ID=1:1234567890:android:abcdef123456
FIREBASE_STORAGE_BUCKET=tradefit-erp-placeholder.appspot.com
FIREBASE_DATABASE_URL=https://tradefit-erp-placeholder.firebaseio.com
FIREBASE_MESSAGING_SENDER_ID=1234567890

